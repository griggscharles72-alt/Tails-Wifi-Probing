#!/bin/bash

BASE_DIR="$HOME/sentinel_logs"
RUN_ID=$(date +"%Y%m%d_%H%M%S")
RUN_DIR="$BASE_DIR/run_$RUN_ID"
MASTER_LOG="$RUN_DIR/master_report.log"

mkdir -p "$RUN_DIR"

echo "===== Sentinel Environment Scan =====" | tee -a "$MASTER_LOG"
echo "Run ID: $RUN_ID" | tee -a "$MASTER_LOG"
echo "Log folder: $RUN_DIR" | tee -a "$MASTER_LOG"
echo "" | tee -a "$MASTER_LOG"

run_check () {
    NUM=$1
    NAME=$2
    CMD=$3
    OUTFILE="$RUN_DIR/${NUM}_${NAME}.log"

    echo "Finding $NUM: $NAME" | tee -a "$MASTER_LOG"

    if eval "$CMD" > "$OUTFILE" 2>&1; then
        echo "✔ Success" | tee -a "$MASTER_LOG"
    else
        echo "⚠ Command failed but continuing" | tee -a "$MASTER_LOG"
    fi

    echo "Log: $OUTFILE" | tee -a "$MASTER_LOG"
    echo "" | tee -a "$MASTER_LOG"
}

# 1 WiFi scan
run_check 1 wifi_scan \
"nmcli -f IN-USE,SSID,BSSID,CHAN,FREQ,SIGNAL,SECURITY dev wifi list"

# 2 wireless interfaces
run_check 2 wifi_interfaces \
"iw dev"

# 3 link telemetry
run_check 3 wifi_link \
"iw dev wlan0 link"

# 4 neighbor table
run_check 4 ip_neighbors \
"ip neigh"

# 5 arp table
run_check 5 arp_table \
"arp -an"

# 6 interface statistics
run_check 6 interface_stats \
"ip -s link"

# 7 saved connections
run_check 7 saved_connections \
"nmcli connection show"

# 8 kernel wifi events
run_check 8 kernel_wifi_events \
"dmesg | grep -i wlan"

# 9 bluetooth scan (short)
run_check 9 bluetooth_scan \
"timeout 10 bluetoothctl scan on"

# 10 network hardware info
run_check 10 network_hardware \
"lshw -C network"

echo "===== Scan Complete =====" | tee -a "$MASTER_LOG"
echo "All logs stored in $RUN_DIR"
