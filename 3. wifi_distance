#!/bin/bash

LOGFILE="$HOME/wifi_distance_log.txt"
TMPFILE="$HOME/wifi_distance_tmp.txt"
declare -A LAST_RSSI

echo "==== Wi-Fi distance log started at $(date) ====" >> "$LOGFILE"

while true; do
    echo "=== Update: $(date) ===" >> "$LOGFILE"

    # Get Wi-Fi list and calculate distances
    nmcli -f SSID,BSSID,SIGNAL,CHAN dev wifi list | tail -n +2 | awk -v LOGFILE_AWK="$LOGFILE" '
    {
        if (match($0, /([0-9A-F]{2}:){5}[0-9A-F]{2}/)) {
            bssid = substr($0, RSTART, RLENGTH)
            ssid = substr($0, 1, RSTART-2)
            split($0, a, bssid)
            signal = a[2]
            rssi = signal / 2 - 100
            chan = $NF
            freq = (chan <= 14) ? 2462 : 5745
            dist = 10^((20 - rssi - 20*log(freq)/log(10) + 27.55)/20)
            timestamp = strftime("%H:%M:%S")
            printf "%.2f %s %s RSSI=%d Distance≈%.2f m [%s]\n", dist, ssid, bssid, rssi, dist, timestamp
            print sprintf("%.2f %s %s RSSI=%d Distance≈%.2f m [%s]", dist, ssid, bssid, rssi, dist, timestamp) >> LOGFILE_AWK
        }
    }' > "$TMPFILE.new" && mv "$TMPFILE.new" "$TMPFILE"

    # Compare RSSI with last scan and log changes
    while read -r line; do
        ssid=$(echo "$line" | awk '{for(i=1;i<=NF;i++) if($i ~ /([0-9A-F]{2}:){5}[0-9A-F]{2}/){print substr($0,1,index($0,$i)-2); break}}')
        bssid=$(echo "$line" | awk '{for(i=1;i<=NF;i++) if($i ~ /([0-9A-F]{2}:){5}[0-9A-F]{2}/){print $i; break}}')
        rssi=$(echo "$line" | awk -F'[ =]' '{for(i=1;i<=NF;i++) if($i=="RSSI"){print $(i+1); break}}')
        key="$bssid"

        last=${LAST_RSSI[$key]:-0}
        if [ "$last" -ne 0 ]; then
            diff=$(( rssi - last ))
            diff=${diff#-}  # absolute value
            if [ "$diff" -ge 3 ]; then
                echo ">>> RSSI change detected for $ssid $bssid: $last -> $rssi"
                echo ">>> RSSI change detected for $ssid $bssid: $last -> $rssi" >> "$LOGFILE"
            fi
        fi

        LAST_RSSI[$key]=$rssi
    done < "$TMPFILE"

    sort -k1 -n "$TMPFILE"  # sort by distance (numeric first column)

    echo "Remember to check $LOGFILE for changes."
    sleep 2
done
